# The Black Rose Signature - Environment Variables

# Server Configuration
PORT=4000
NODE_ENV=development

# Stripe Configuration (for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Email Service (for newsletter)
EMAIL_SERVICE_API_KEY=your_email_api_key

# Database (optional - for future MongoDB integration)
MONGODB_URI=mongodb://localhost:27017/blackrose
