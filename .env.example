# The Black Rose Signature - Environment Variables
# Copy this file to ".env" and fill in real values. Never commit ".env".

# Server Configuration
PORT=4000
NODE_ENV=development

# Stripe Configuration (for production payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Email Service (for newsletter)
EMAIL_SERVICE_API_KEY=your_email_api_key

# Database — MongoDB Atlas connection string.
# When set, products/inventory persist in MongoDB (required for the admin
# panel to persist on Vercel). When unset, the app falls back to the local
# data/products.json file (fine for local dev only).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/blackrose?retryWrites=true&w=majority

# Admin panel authentication (required in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password
JWT_SECRET=change_this_to_a_long_random_string
